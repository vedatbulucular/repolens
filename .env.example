# Public development ports
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# API settings
REPOLENS_API_DEBUG=false
REPOLENS_API_DATABASE_URL=postgresql+asyncpg://repolens:repolens-local@localhost:5432/repolens
REPOLENS_API_REDIS_URL=redis://localhost:6379/0
REPOLENS_API_BROKER_VISIBILITY_TIMEOUT_SECONDS=300
REPOLENS_API_ACQUISITION_TIMEOUT_SECONDS=60
REPOLENS_API_MAX_REPOSITORY_BYTES=104857600
REPOLENS_API_MAX_WORKSPACE_BYTES=268435456
REPOLENS_API_MAX_FILE_COUNT=20000
REPOLENS_API_MAX_FILE_BYTES=5242880
REPOLENS_API_MAX_PATH_LENGTH=512
REPOLENS_API_MAX_PATH_DEPTH=40
REPOLENS_API_INVENTORY_TIMEOUT_SECONDS=20
REPOLENS_API_MAX_INVENTORY_ENTRIES=20000
REPOLENS_API_MAX_INVENTORY_DIRECTORIES=5000
REPOLENS_API_MAX_INVENTORY_PATH_LENGTH=512
REPOLENS_API_MAX_MANIFEST_BYTES=1048576
REPOLENS_API_MAX_TEXT_READ_BYTES=262144
REPOLENS_API_BINARY_SAMPLE_BYTES=8192
REPOLENS_API_MAX_ANALYSIS_WARNINGS=200
REPOLENS_API_MAX_JSON_NESTING_DEPTH=32
REPOLENS_API_MAX_MANIFEST_NODES=50000
REPOLENS_API_MAX_TECHNOLOGY_FINDINGS=100
REPOLENS_API_MAX_TECHNOLOGY_EVIDENCE_PER_FINDING=20
REPOLENS_API_MAX_ENTRY_POINTS=100
# Native worker setting; Docker Compose always uses its bounded workspace tmpfs.
REPOLENS_API_WORKSPACE_ROOT=/tmp/repolens-workspaces

# Docker Compose worker limits
REPOLENS_WORKER_CONCURRENCY=2
REPOLENS_WORKER_MEMORY_LIMIT=1536m
REPOLENS_WORKER_CPU_LIMIT=2.0
REPOLENS_WORKER_PIDS_LIMIT=64
REPOLENS_WORKER_WORKSPACE_TMPFS_SIZE=671088640
REPOLENS_WORKER_RUNTIME_TMPFS_SIZE=67108864
REPOLENS_WORKER_SHM_SIZE=64m
REPOLENS_WORKER_STOP_GRACE_PERIOD=90s

# Development-only infrastructure credentials
POSTGRES_DB=repolens
POSTGRES_USER=repolens
POSTGRES_PASSWORD=repolens-local
