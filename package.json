{
  "name": "repolens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "uv --directory apps/api run uvicorn repolens_api.main:app --reload --host 0.0.0.0 --port 8000",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm --dir apps/web test",
    "test:api": "uv --directory apps/api run pytest",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm --dir apps/web lint",
    "lint:api": "uv --directory apps/api run ruff format --check . && uv --directory apps/api run ruff check .",
    "type-check": "pnpm type-check:web && pnpm type-check:api",
    "type-check:web": "pnpm --dir apps/web type-check",
    "type-check:api": "uv --directory apps/api run mypy src tests",
    "build:web": "pnpm --dir apps/web build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
